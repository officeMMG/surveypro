# ================================================================
# SurveyPro 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、実際の値を入力してください
# .env.local は Git 管理外（.gitignore に追加済み）
# ================================================================

# ── 認証（NextAuth.js） ──────────────────────────────────────────
# ランダム文字列: openssl rand -base64 32 で生成
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials で取得
# 承認済みリダイレクトURI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── データベース（Supabase） ─────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string
# "Transaction" モード（ポート6543）を使用
DATABASE_URL=postgresql://postgres.[xicczgqnjhzhmtgqawtn]:[OfficeMMG568323]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# "Session" モード（ポート5432）— Prisma migrate 用
DIRECT_URL=postgresql://postgres.[xicczgqnjhzhmtgqawtn]:[OfficeMMG568323]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# ── APIキー暗号化キー ─────────────────────────────────────────────
# AES-256-GCM 用: openssl rand -hex 32 で生成（64文字の16進数）
# 絶対に Git にコミットしないこと
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# ── Anthropic API ─────────────────────────────────────────────────
# https://console.anthropic.com/ で取得
# サーバーサイドのみ使用。NEXT_PUBLIC_ プレフィックス禁止
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Vercel Blob（写真保存） ───────────────────────────────────────
# Vercel Dashboard → Storage → Blob → Create Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Sentry（エラー監視） ─────────────────────────────────────────
# https://sentry.io/ でプロジェクト作成後に取得
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── アプリ設定 ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 現場の最大保存件数（超過時に古い順から自動削除）
MAX_PROJECTS_PER_USER=500
# 現場の自動削除までの日数
PROJECT_AUTO_DELETE_DAYS=180
