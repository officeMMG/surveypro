# ================================================================
# SurveyPro 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、実際の値を入力してください
# .env.local は Git 管理外（.gitignore に追加済み）
# ================================================================

# ── 認証（NextAuth.js） ──────────────────────────────────────────
# ランダム文字列: openssl rand -base64 32 で生成
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials で取得
# 承認済みリダイレクトURI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── データベース（PostgreSQL） ───────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/surveypro

# ── Dify Cloud ───────────────────────────────────────────────────
# https://cloud.dify.ai のワークスペース設定から取得
DIFY_API_URL=https://api.dify.ai

# 統合ワークフロー (leveling) の API キー
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxx

# ── Sentry（エラー監視） ─────────────────────────────────────────
# https://sentry.io/ でプロジェクト作成後に取得
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── アプリ設定 ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 現場の最大保存件数
MAX_PROJECTS_PER_USER=500
# 現場の自動削除までの日数
PROJECT_AUTO_DELETE_DAYS=180
